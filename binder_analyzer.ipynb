   "outputs": [],
   "source": [
    "# Contact map (ipTM shown in title if available)\n",
    "fig = analyzer.plot_contact_map(\n",
    "    figsize=(10, 8), \n",
    "    distance_threshold=8.0\n",
    ")\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Access Metrics Programmatically"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Access metrics object directly\n",
    "if analyzer.metrics:\n",
    "    print(\"Available Metrics:\")\n",
    "    print(f\"  ipTM: {analyzer.metrics.iptm}\")\n",
    "    print(f\"  pTM:  {analyzer.metrics.ptm}\")\n",
    "    print(f\"  mean pLDDT: {analyzer.metrics.plddt.mean():.2f}\")\n",
    "    print(f\"  mean PAE: {analyzer.metrics.pae.mean():.2f}\")\n",
    "    \n",
    "    # Get pLDDT for specific chain\n",
    "    plddt_a = analyzer.metrics.get_plddt_for_chain('A')\n",
    "    plddt_b = analyzer.metrics.get_plddt_for_chain('B')\n",
    "    print(f\"\\nChain A pLDDT: {plddt_a.mean():.2f} ± {plddt_a.std():.2f}\")\n",
    "    print(f\"Chain B pLDDT: {plddt_b.mean():.2f} ± {plddt_b.std():.2f}\")\n",
    "    \n",
    "    # Get interface PAE\n",
    "    interface_pae = analyzer.metrics.get_interface_pae('A', 'B')\n",
    "    print(f\"\\nInterface PAE (A-B): {interface_pae:.2f} Å\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Compare Multiple Models with Metrics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Generate ensemble with varying confidence\n",
    "def generate_ensemble_with_metrics(n_models=3):\n",
    "    \"\"\"Generate ensemble with varying quality.\"\"\"\n",
    "    pdb_files = []\n",
    "    json_files = []\n",
    "    \n",
    "    for i in range(n_models):\n",
    "        # Vary quality: model 0 is best, model 2 is worst\n",
    "        quality_factor = 1.0 - i * 0.2\n",
    "        \n",
    "        pdb_file = f\"ensemble_model_{i+1}.pdb\"\n",
    "        json_file = f\"ensemble_model_{i+1}_confidences.json\"\n",
    "        \n",
    "        # Generate PDB\n",
    "        generate_sample_pdb(pdb_file)\n",
    "        \n",
    "        # Generate confidence with varying quality\n",
    "        n_res_a, n_res_b = 50, 30\n",
    "        n_total = n_res_a + n_res_b\n",
    "        \n",
    "        plddt = []\n",
    "        chain_ids = []\n",
    "        for j in range(n_res_a):\n",
    "            score = (95 - abs(j - 25) * 1.5) * quality_factor\n",
    "            plddt.append(max(30, min(100, score + np.random.randn() * 3)))\n",
    "            chain_ids.append('A')\n",
    "        for j in range(n_res_b):\n",
    "            score = 88 * quality_factor\n",
    "            plddt.append(max(50, min(100, score + np.random.randn() * 5)))\n",
    "            chain_ids.append('B')\n",
    "        \n",
    "        # PAE increases with lower quality\n",
    "        pae = np.random.rand(n_total, n_total) * 5 + (1 - quality_factor) * 10\n",
    "        \n",
    "        data = {\n",
    "            'iptm': 0.87 * quality_factor,\n",
    "            'ptm': 0.82 * quality_factor,\n",
    "            'ranking_score': 0.85 * quality_factor,\n",
    "            'plddt': plddt,\n",
    "            'chain_ids': chain_ids,\n",
    "            'pae': pae.tolist()\n",
    "        }\n",
    "        \n",
    "        with open(json_file, 'w') as f:\n",
    "            json.dump(data, f, indent=2)\n",
    "        \n",
    "        pdb_files.append(pdb_file)\n",
    "        json_files.append(json_file)\n",
    "    \n",
    "    return pdb_files, json_files\n",
    "\n",
    "pdb_files, json_files = generate_ensemble_with_metrics(3)\n",
    "print(\"Generated ensemble:\")\n",
    "for p, j in zip(pdb_files, json_files):\n",
    "    print(f\"  {p} + {j}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compare models with metrics\n",
    "comparison = analyze_multiple_structures(\n",
    "    pdb_files, \n",
    "    confidence_files=json_files,\n",
    "    distance_threshold=7.0\n",
    ")\n",
    "comparison"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize comparison\n",
    "fig, axes = plt.subplots(2, 2, figsize=(12, 10))\n",
    "\n",
    "# Epitope size\n",
    "axes[0, 0].bar(comparison['file'], comparison['epitope_residues'], color='coral')\n",
    "axes[0, 0].set_ylabel('Residues')\n",
    "axes[0, 0].set_title('Epitope Size')\n",
    "axes[0, 0].tick_params(axis='x', rotation=45)\n",
    "\n",
    "# ipTM comparison\n",
    "if 'ipTM' in comparison.columns:\n",
    "    axes[0, 1].bar(comparison['file'], comparison['ipTM'], color='steelblue')\n",
    "    axes[0, 1].set_ylabel('ipTM')\n",
    "    axes[0, 1].set_title('Interface Confidence (ipTM)')\n",
    "    axes[0, 1].set_ylim(0, 1)\n",
    "    axes[0, 1].tick_params(axis='x', rotation=45)\n",
    "\n",
    "# Mean pLDDT\n",
    "if 'mean_plddt' in comparison.columns:\n",
    "    axes[1, 0].bar(comparison['file'], comparison['mean_plddt'], color='seagreen')\n",
    "    axes[1, 0].set_ylabel('Mean pLDDT')\n",
    "    axes[1, 0].set_title('Per-Residue Confidence')\n",
    "    axes[1, 0].set_ylim(0, 100)\n",
    "    axes[1, 0].tick_params(axis='x', rotation=45)\n",
    "\n",
    "# Mean PAE\n",
    "if 'mean_pae' in comparison.columns:\n",
    "    axes[1, 1].bar(comparison['file'], comparison['mean_pae'], color='orange')\n",
    "    axes[1, 1].set_ylabel('Mean PAE (Å)')\n",
    "    axes[1, 1].set_title('Predicted Aligned Error')\n",
    "    axes[1, 1].tick_params(axis='x', rotation=45)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },

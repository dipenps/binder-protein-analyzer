   "source": [
    "# Binder-Protein Analyzer\n",
    "\n",
    "This notebook demonstrates the analysis of protein-binder complexes from PDB/CIF files with **AlphaFold/Boltz confidence metrics** support.\n",
    "\n",
    "**Features:**\n",
    "- Load structures from AlphaFold 3, Boltz, or other prediction tools\n",
    "- Parse confidence metrics: **ipTM, pTM, pLDDT, PAE**\n",
    "- Identify residue contacts (4-6 Å)\n",
    "- Generate sequence proximity visualizations\n",
    "- Overlay confidence scores on contact analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Import the analyzer\n",
    "from analyzer import BinderAnalyzer, AlphafoldMetrics, analyze_multiple_structures\n",
    "import matplotlib.pyplot as plt\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import json\n",
    "\n",
    "%matplotlib inline\n",
    "plt.style.use('default')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Create Sample Data with Confidence Metrics\n",
    "\n",
    "Generate a sample PDB and corresponding confidence JSON (like AlphaFold/Boltz output)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Generate sample PDB structure\n",
    "def generate_sample_pdb(filename=\"sample_complex.pdb\", n_res_a=50, n_res_b=30):\n",
    "    \"\"\"Generate a sample PDB with two chains in contact.\"\"\"\n",
    "    atom_num = 1\n",
    "    res_names = ['ALA', 'VAL', 'LEU', 'ILE', 'PHE', 'TRP', 'TYR', 'MET', \n",
    "                 'GLY', 'SER', 'THR', 'CYS', 'PRO', 'ASN', 'GLN', \n",
    "                 'ASP', 'GLU', 'LYS', 'ARG', 'HIS']\n",
    "    \n",
    "    lines = [\"REMARK   1 SAMPLE PROTEIN-BINDER COMPLEX\",\n",
    "             \"CRYST1   80.000   80.000   80.000  90.00  90.00  90.00 P 1           1\"]\n",
    "    \n",
    "    # Chain A (protein) - extended conformation\n",
    "    for i in range(n_res_a):\n",
    "        res_name = res_names[i % len(res_names)]\n",
    "        x = i * 3.8\n",
    "        lines.append(f\"ATOM  {atom_num:5d}  CA  {res_name:3s} A{i+1:4d}    {x:8.3f}{0.0:8.3f}{0.0:8.3f}  1.00 20.00           C\")\n",
    "        atom_num += 1\n",
    "    \n",
    "    # Chain B (binder) - positioned to create contacts\n",
    "    contact_center = n_res_a // 2\n",
    "    for i in range(n_res_b):\n",
    "        res_name = res_names[(i+5) % len(res_names)]\n",
    "        x = (contact_center - n_res_b//2 + i) * 3.8\n",
    "        y = 5.0 + np.sin(i * 0.5) * 2\n",
    "        z = 3.0\n",
    "        lines.append(f\"ATOM  {atom_num:5d}  CA  {res_name:3s} B{i+1:4d}    {x:8.3f}{y:8.3f}{z:8.3f}  1.00 20.00           C\")\n",
    "        atom_num += 1\n",
    "    \n",
    "    lines.append(\"END\")\n",
    "    \n",
    "    with open(filename, 'w') as f:\n",
    "        f.write('\\n'.join(lines))\n",
    "    return filename\n",
    "\n",
    "# Generate sample confidence JSON (AlphaFold 3 format)\n",
    "def generate_sample_confidence(filename=\"sample_complex_confidences.json\", n_res_a=50, n_res_b=30):\n",
    "    \"\"\"Generate sample AlphaFold-style confidence JSON.\"\"\"\n",
    "    n_total = n_res_a + n_res_b\n",
    "    \n",
    "    # Generate pLDDT scores (higher near interface)\n",
    "    plddt = []\n",
    "    chain_ids = []\n",
    "    \n",
    "    # Chain A: vary pLDDT\n",
    "    for i in range(n_res_a):\n",
    "        # Higher confidence in middle (interface region)\n",
    "        dist_from_center = abs(i - n_res_a//2)\n",
    "        score = 95 - dist_from_center * 1.5 + np.random.randn() * 3\n",
    "        plddt.append(max(30, min(100, score)))\n",
    "        chain_ids.append('A')\n",
    "    \n",
    "    # Chain B: high confidence\n",
    "    for i in range(n_res_b):\n",
    "        score = 88 + np.random.randn() * 5\n",
    "        plddt.append(max(50, min(100, score)))\n",
    "        chain_ids.append('B')\n",
    "    \n",
    "    # Generate PAE matrix (lower error near diagonal and interface)\n",
    "    pae = np.zeros((n_total, n_total))\n",
    "    for i in range(n_total):\n",
    "        for j in range(n_total):\n",
    "            # Within same chain: lower PAE\n",
    "            if chain_ids[i] == chain_ids[j]:\n",
    "                pae[i, j] = abs(i - j) * 0.3 + np.random.rand() * 2\n",
    "            else:\n",
    "                # Between chains: moderate PAE\n",
    "                pae[i, j] = 8 + np.random.rand() * 4\n",
    "    \n",
    "    data = {\n",
    "        'iptm': 0.87,  # High interface confidence\n",
    "        'ptm': 0.82,   # Good overall fold\n",
    "        'ranking_score': 0.85,\n",
    "        'plddt': plddt,\n",
    "        'chain_ids': chain_ids,\n",
    "        'pae': pae.tolist()\n",
    "    }\n",
    "    \n",
    "    with open(filename, 'w') as f:\n",
    "        json.dump(data, f, indent=2)\n",
    "    \n",
    "    return filename\n",
    "\n",
    "# Generate sample files\n",
    "sample_pdb = generate_sample_pdb()\n",
    "sample_json = generate_sample_confidence()\n",
    "\n",
    "print(f\"Generated: {sample_pdb}, {sample_json}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Load Structure with Confidence Metrics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Initialize analyzer with confidence JSON\n",
    "analyzer = BinderAnalyzer(\n",
    "    sample_pdb, \n",
    "    protein_chain='A', \n",
    "    binder_chain='B',\n    "    confidence_json=sample_json  # Auto-detected if in same directory\n",
    ")\n",
    "\n",
    "# Calculate contacts\n",
    "analyzer.calculate_contacts(distance_threshold=6.0)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Print full summary including confidence metrics\n",
    "analyzer.print_summary()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Visualize Confidence Metrics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Plot pLDDT per residue\n",
    "fig = analyzer.plot_plddt(figsize=(14, 4))\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Plot PAE matrix\n",
    "fig = analyzer.plot_pae_matrix(figsize=(10, 8))\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Sequence Proximity with pLDDT Overlay"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Plot with pLDDT panel\n",
    "fig = analyzer.plot_sequence_proximity(\n",
    "    figsize=(14, 9),\n",
    "    distance_range=(4.0, 8.0),\n",
    "    show_plddt=True  # Add pLDDT as third panel\n",
    ")\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Contact Map with Confidence"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
